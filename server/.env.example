PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/swiftie

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_256_bit_random_secret_here
JWT_EXPIRY=7d

# Firebase Admin — path to your downloaded service account JSON
# In production on Render, set FIREBASE_SERVICE_ACCOUNT_JSON as the raw JSON string instead
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# CORS — set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
