{
  "expo": {
    "name": "Swiftie",
    "slug": "swiftie-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "swiftie",
    "userInterfaceStyle": "dark",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000105"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nipunjaiswal.swiftie"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000105"
      },
      "package": "com.nipunjaiswal.swiftie"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
